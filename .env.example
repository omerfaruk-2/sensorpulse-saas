# SensorPulse SaaS — Ortam Değişkenleri Şablonu
# Bu dosyayı ".env" olarak kopyalayın ve değerleri kendi ortamınıza göre güncelleyin.

POSTGRES_USER=sensoruser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sensorpulse
DATABASE_URL=postgresql://sensoruser:changeme@db:5432/sensorpulse
ADMIN_API_KEY=changeme
ALLOWED_ORIGINS=http://localhost:8501
API_BASE_URL=http://localhost:8000
